rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anyone to create new orders (unauthenticated users)
    match /orders/{orderId} {
      allow create: if true;
      
      // Allow authenticated users to read all orders
      allow read: if request.auth != null;
      
      // Allow authenticated users to update order status
      allow update: if request.auth != null && 
                       resource.data.keys().hasOnly(['network', 'plan', 'price', 'phoneNumber', 'email', 'paymentRef', 'status', 'createdAt']);
    }
  }
}
